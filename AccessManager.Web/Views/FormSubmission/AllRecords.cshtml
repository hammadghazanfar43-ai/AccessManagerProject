@model IEnumerable<Model.FormSubmission>

@{
    ViewData["Title"] = "All Records";
}

<h3 class="mb-3">All Submitted Forms</h3>

<table class="table table-bordered table-striped table-sm" id="recordsTable">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email Status</th>
            <th class="text-center" style="min-width: 180px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>
                        @if (item.EmailStatus == "Sent")
                        {
                            <span class="badge bg-success">Sent</span>
                        }
                        else if (item.EmailStatus == "Failed")
                        {
                            <span class="badge bg-danger">Failed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </td>
                    <td class="text-center">
                        <a href="@Url.Action("ViewRecord", "FormSubmission", new { id = item.Id })" class="btn btn-sm btn-info">👁️</a>
                        <a href="@Url.Action("EditRecord", "FormSubmission", new { id = item.Id })" class="btn btn-sm btn-warning">✏️</a>
                        <a href="javascript:void(0);" class="btn btn-sm btn-danger delete-btn" data-id="@item.Id">🗑️</a>
                        <a href="javascript:void(0);" class="btn btn-sm btn-secondary email-btn" 
                           data-id="@item.Id" data-email="@item.Email">📧</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center">No data found</td>
            </tr>
        }
    </tbody>
</table>

<!-- Email Modal -->
<div class="modal fade" id="emailModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content p-3">
            <h5>Send Form via Email</h5>
            <input type="hidden" id="recordId" />
            <div class="form-group">
                <label>To Email</label>
                <input type="email" class="form-control" id="emailTo" placeholder="Enter recipient email" />
            </div>
            <button id="sendEmailBtn" class="btn btn-primary mt-2">Send</button>
        </div>
    </div>
</div>


@section Styles {
    <style>
        

        /* Pagination container */
        .dataTables_paginate {
            margin-top: 20px;
            display: flex;
            justify-content: center;
            gap: 6px;
        }

            /* All pagination buttons (numbers + first/prev/next/last) */
            .dataTables_paginate .paginate_button {
                padding: 6px 12px;
                border: 1px solid #ccc;
                background-color: #f9f9f9 !important;
                cursor: pointer;
                border-radius: 6px;
                font-size: 14px;
                transition: all 0.2s ease-in-out;
                color: #333 !important;
            }

                /* Hover effect for all buttons */
                .dataTables_paginate .paginate_button:hover:not(.disabled) {
                    background: linear-gradient(135deg, #0061ff, #60efff) !important; /* Royal Blue → Aqua */
                    color: white !important;
                    border: none !important;
                    box-shadow: 0px 3px 6px rgba(0,0,0,0.15);
                }

                /* Disabled state (First/Prev when on first page, Next/Last when on last page) */
                .dataTables_paginate .paginate_button.disabled {
                    opacity: 0.5;
                    cursor: default;
                    background-color: #f9f9f9 !important;
                    border: 1px solid #ccc !important;
                    color: #999 !important;
                    box-shadow: none !important;
                }

                /* Current active page */
                .dataTables_paginate .paginate_button.current {
                    background: linear-gradient(135deg, #0061ff, #60efff) !important; /* Royal Blue → Aqua */
                    color: white !important;
                    font-weight: bold;
                    border: none !important;
                    box-shadow: 0px 3px 6px rgba(0,0,0,0.15);
                }

                    /* Hover effect for active page */
                    .dataTables_paginate .paginate_button.current:hover {
                        background: linear-gradient(135deg, #0051d4, #4ddde0) !important; /* Slightly darker Royal Blue → Aqua */
                        color: white !important;
                    }

        /* Search box positioning */
        .dataTables_wrapper .dataTables_filter {
            float: right;
        }

        /* Center pagination text */
        .dataTables_wrapper .dataTables_paginate {
            float: none;
            text-align: center;
        }

        /* Table header background */
        #recordsTable thead th {
            background: linear-gradient(135deg, #0061ff, #60efff) !important; /* Royal Blue → Aqua */
            color: white !important;
            padding: 10px;
            font-weight: bold;
            text-align: center;
            transition: background 0.3s ease-in-out;
        }

            /* Hover effect for table header */
            #recordsTable thead th:hover {
                background: linear-gradient(135deg, #0051d4, #4ddde0) !important; /* Slightly darker Royal Blue → Aqua */
                cursor: pointer;
            }


        .btn-gradient {
            background: linear-gradient(135deg, #0061ff, #60efff);
            color: white;
            border: none;
            box-shadow: 0px 3px 6px rgba(0,0,0,0.15);
            transition: all 0.2s ease-in-out;
        }

            .btn-gradient:hover {
                background: linear-gradient(135deg, #0051d4, #4ddde0);
                color: white;
            }
        /* Center pagination and info text */
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            float: none !important;
            text-align: center !important;
            margin: 10px 0;
        }

        /* Make pagination buttons inline with info text */
        .dataTables_wrapper .dataTables_info {
            display: block;
            margin-bottom: 5px;
        }



    </style>
}


@section Scripts {
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />

    <script>
        $(document).ready(function () {
            // DataTable with pagination
            $('#recordsTable').DataTable({
                "pageLength": 10,
                "lengthChange": false,
                "info": false,
                "pagingType": "full_numbers",
                "language": {
                    "paginate": {
                        "first": "First",
                        "last": "Last",
                        "next": "Next",
                        "previous": "Previous"
                    }
                }
            });

            // Open email modal
            $('.email-btn').click(function () {
                const id = $(this).data('id');
                const email = $(this).data('email');
                $('#recordId').val(id);
                $('#emailTo').val(email);
                $('#emailModal').modal('show');
            });

            // Send email via AJAX
            $('#sendEmailBtn').click(function () {
                const id = $('#recordId').val();
                const email = $('#emailTo').val();

                $.ajax({
                    url: '/FormSubmission/SendFormEmail',
                    type: 'POST',
                    data: { id: id, toEmail: email },
                    success: function (res) {
                        if (res.success) {
                            toastr.success('Email sent successfully!');
                            $('#emailModal').modal('hide');
                        } else {
                            toastr.error('Failed to send email.');
                        }
                    },
                    error: function () {
                        toastr.error('Error sending email.');
                    }
                });
            });

            // Delete record
            $('.delete-btn').click(function () {
                if (!confirm("Are you sure you want to delete this record?")) return;

                var id = $(this).data('id');
                $.ajax({
                    url: '/FormSubmission/DeleteRecord',
                    type: 'POST',
                    data: { id: id },
                    success: function (res) {
                        if (res.success) {
                            toastr.success('Record deleted successfully.');
                            location.reload();
                        } else {
                            toastr.error('Failed to delete.');
                        }
                    },
                    error: function () {
                        toastr.error('Something went wrong.');
                    }
                });
            });
        });
    </script>
}
<h3 class="mb-3 d-flex justify-content-between align-items-center">
  
    <a href="@Url.Action("Dashboard", "Home")" class="btn btn-gradient btn-sm">⬅ Back</a>
</h3>


