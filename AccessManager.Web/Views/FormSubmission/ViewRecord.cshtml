@model Model.FormSubmission

@{
    ViewData["Title"] = "View Record";
}

<h3>Form Submission Details</h3>
<table class="table table-bordered table-sm">
    <tr><th>Name</th><td>@Model.Name</td></tr>
    <tr><th>Father Name</th><td>@Model.FatherName</td></tr>
    <tr><th>CNIC</th><td>@Model.CNIC</td></tr>
    <tr><th>Email</th><td>@Model.Email</td></tr>
    <tr><th>Phone</th><td>@Model.Phone</td></tr>
    <tr><th>Marital Status</th><td>@Model.MaritalStatus</td></tr>
    <tr><th>Address</th><td>@Model.Address</td></tr>
    <tr><th>Age</th><td>@Model.Age</td></tr>
    <tr><th>DOB</th><td>@Model.DOB:yyyy-MM-dd</td></tr>
    <tr><th>Nationality</th><td>@Model.Nationality</td></tr>
    <tr><th>Occupation</th><td>@Model.Occupation</td></tr>
    <tr><th>Gender</th><td>@Model.Gender</td></tr>
    <tr><th>City</th><td>@Model.City</td></tr>
    <tr><th>Country</th><td>@Model.Country</td></tr>
    <tr><th>Country Code</th><td>@Model.CountryCode</td></tr>
</table>
<a class="btn btn-secondary btn-sm" href="@Url.Action("AllRecords")">Back</a>
